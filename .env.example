# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173

# Google Sheets Configuration
VITE_SPREADSHEET_ID=your_google_sheet_id_here

# Google Docs Templates
VITE_TEMPLATE_FACTURE_ID=your_facture_template_doc_id_here
VITE_TEMPLATE_RECU_ID=your_recu_template_doc_id_here

# Google Drive Folders
VITE_DRIVE_FOLDER_FACTURES_ID=your_factures_folder_id_here
VITE_DRIVE_FOLDER_RECUS_ID=your_recus_folder_id_here
